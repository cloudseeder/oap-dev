api:
  host: "127.0.0.1"
  port: 8303

database:
  path: "oap_agent.db"

discovery:
  url: "http://localhost:8300"
  model: "qwen3:8b"
  timeout: 120

voice:
  enabled: true
  whisper_model: "base"
  tts_enabled: true
  tts_model_path: ""          # absolute path to .onnx voice file
  tts_models_dir: "piper-voices"  # directory to scan for available voices
